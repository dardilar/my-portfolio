---
import Layout from "@/layouts/Layout.astro"

import AboutMe from "@/components/AboutMe.astro"
import Briefcase from "@/components/icons/Briefcase.astro"
import CodeIcon from "@/components/icons/Code.astro"
import Experience from "@/components/Experience.astro"
import Education from "@/components/Education.astro"
import GraduationCap from "@/components/icons/GraduationCap.astro"
import TechStack from "@/components/TechStack.astro"
import ProfileCheck from "@/components/icons/ProfileCheck.astro"
import Projects from "@/components/Projects.astro"
import SectionContainer from "@/components/SectionContainer.astro"
import Hero from "@/components/Hero.astro"
import TitleSection from "@/components/TitleSection.astro"
---

<Layout
  title="Duvan Ardila — Frontend Developer & Engineer"
  description="Portfolio of Duvan Ardila, Frontend Developer and Electromechanical Engineer with 4+ years building web solutions as an Oracle contractor. Now expanding into Full Stack and AI Engineering with React, Node.js, TypeScript and Python."
>
  <main class="px-4">
    <SectionContainer class="py-16 md:py-36">
      <Hero />
    </SectionContainer>
    <div class="space-y-24">
    <SectionContainer id="experience">
      <TitleSection>
        <Briefcase class="size-8" />
        Experience
      </TitleSection>
      <Experience />
    </SectionContainer>

    <SectionContainer id="stack">
      <TitleSection>
        <CodeIcon class="size-7" />
        Tech Stack
      </TitleSection>
      <div class="mt-8">
        <TechStack />
      </div>
    </SectionContainer>

    <SectionContainer id="education">
      <TitleSection>
        <GraduationCap class="size-8" />
        Education
      </TitleSection>
      <Education />
    </SectionContainer>

    <SectionContainer id="projects">
      <TitleSection>
        <CodeIcon class="size-7" />
        Projects
      </TitleSection>
      <Projects />
    </SectionContainer>

    <SectionContainer id="about-me">
      <TitleSection>
        <ProfileCheck class="size-8" />
        About me
      </TitleSection>
      <AboutMe />
    </SectionContainer>
  </div>
  </main>
</Layout>
