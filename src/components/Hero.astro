---
const personalImageAlt = "Duvan Ardila"
import Badge from "@/components/Badge.astro"
import LinkedInIcon from "@/components/icons/LinkedIn.astro"
import MailIcon from "@/components/icons/Mail.astro"
import GitHubIcon from "@/components/icons/GitHub.astro"
import DownloadIcon from "@/components/icons/Download.astro"
import SocialPill from "@/components/SocialPill.astro"
---

<div class="max-w-2xl">
  <div class="flex gap-4 mb-4">
    <img
      class="transition duration-300 rounded-full shadow-lg size-16 hover:scale-105 hover:shadow-xl"
      src="/duvan.png"
      alt={personalImageAlt}
    />
    <a
      href="https://www.linkedin.com/in/dardilar/"
      target="_blank"
      rel="noopener"
      class="flex items-center transition md:justify-center md:hover:scale-105"
    >
      <Badge>Available to work</Badge>
    </a>
  </div>
  <h1 class="min-h-[5rem] text-4xl font-bold tracking-tight text-gray-800 sm:min-h-[7rem] sm:text-5xl dark:text-white">
    <span aria-hidden="true"
      ><span id="typed-intro">Hello there, I'm Duvan!</span><br /><span
        id="typed-role"
        class="text-yellow-500 dark:text-yellow-300">Frontend Developer</span
      ><span
        id="typed-cursor"
        class="type-cursor text-yellow-500 dark:text-yellow-300"></span
    ></span>
    <span class="sr-only">Hello there, I'm Duvan! Frontend Developer and Engineer.</span>
  </h1>
  <p class="mt-6 text-xl text-gray-800 dark:[&>strong]:text-yellow-200 [&>strong]:text-yellow-500 [&>strong]:font-semibold dark:text-gray-300"><strong>4+ years</strong> building web solutions as an Oracle contractor, based in Bogotá 🇨🇴. Now expanding into <strong>Full Stack & AI Engineering</strong>.</p>
  <nav class="flex flex-wrap gap-4 mt-8">
    <SocialPill href="mailto:dsardila1809@gmail.com?subject=Hey%20Duvan!%20%F0%9F%91%8B&body=Hi%20Duvan%2C%0A%0AI%20came%20across%20your%20portfolio%20and%20">
      <MailIcon class="size-4" />
      Contact me at
    </SocialPill>
    <SocialPill href="https://www.linkedin.com/in/dardilar/">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
    <SocialPill href="https://github.com/dardilar">
      <GitHubIcon class="size-4" />
      GitHub
    </SocialPill>
    <SocialPill href="/Duvan-Ardila-CV.pdf" download="Duvan-Ardila-CV.pdf">
      <DownloadIcon class="size-4" />
      Download CV
    </SocialPill>
  </nav>
</div>

<style>
  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .type-cursor {
    display: inline-block;
    width: 2px;
    height: 1.1em;
    margin-left: 0.1em;
    vertical-align: -0.18em;
    background: currentColor;
    border-radius: 1px;
    animation: blink 1.05s steps(1) infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .type-cursor {
      display: none;
    }
  }
</style>

<script>
  const INTRO = "Hello there, I'm Duvan!"
  const ROLES = [
    "Frontend Developer",
    "Electromechanical Engineer",
    "AI Enthusiast",
    "Full Stack — Soon",
  ]

  function startTypewriter() {
    const intro = document.getElementById("typed-intro")
    const role = document.getElementById("typed-role")
    const cursor = document.getElementById("typed-cursor")
    if (!intro || !role || !cursor) return

    const prefersReduced = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches
    if (prefersReduced) {
      intro.textContent = INTRO
      role.textContent = ROLES[0]
      return
    }

    // Guard against duplicate loops when View Transitions re-run the script.
    if (intro.dataset.typing === "true") return
    intro.dataset.typing = "true"

    const introEl = intro
    const roleEl = role
    const cursorEl = cursor

    // Start from a clean slate, caret on the first line.
    introEl.textContent = ""
    roleEl.textContent = ""
    introEl.after(cursorEl)

    let i = 0
    function typeIntro() {
      i++
      introEl.textContent = INTRO.slice(0, i)
      if (i < INTRO.length) {
        window.setTimeout(typeIntro, 90)
      } else {
        // Move caret down to the role line and start the rotation.
        roleEl.after(cursorEl)
        window.setTimeout(loopRoles, 600)
      }
    }

    let roleIndex = 0
    let charIndex = 0
    let deleting = false
    function loopRoles() {
      const current = ROLES[roleIndex]

      if (deleting) {
        charIndex--
        roleEl.textContent = current.slice(0, charIndex)
        if (charIndex === 0) {
          deleting = false
          roleIndex = (roleIndex + 1) % ROLES.length
        }
      } else {
        charIndex++
        roleEl.textContent = current.slice(0, charIndex)
        if (charIndex === current.length) {
          deleting = true
          window.setTimeout(loopRoles, 1800)
          return
        }
      }

      window.setTimeout(loopRoles, deleting ? 70 : 130)
    }

    typeIntro()
  }

  document.addEventListener("astro:page-load", startTypewriter)
</script>
