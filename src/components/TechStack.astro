---
import HTML from "./icons/HTML.astro"
import CSS from "./icons/CSS.astro"
import Javascript from "./icons/Javascript.astro"
import Typescript from "./icons/Typescript.astro"
import Tailwind from "./icons/Tailwind.astro"
import AstroIcon from "./icons/Astro.astro"
import React from "./icons/React.astro"
import NodeJS from "./icons/NodeJS.astro"
import Python from "./icons/Python.astro"
import GitHub from "./icons/GitHub.astro"

const GROUPS = [
  {
    title: "Core & Frontend",
    items: [
      { name: "HTML", icon: HTML },
      { name: "CSS", icon: CSS },
      { name: "JavaScript", icon: Javascript },
      { name: "TypeScript", icon: Typescript },
      { name: "Tailwind CSS", icon: Tailwind },
      { name: "Astro", icon: AstroIcon },
    ],
  },
  {
    title: "Full Stack & AI (in progress)",
    items: [
      { name: "React", icon: React },
      { name: "Node.js", icon: NodeJS },
      { name: "Python", icon: Python },
      { name: "Claude" },
      { name: "Codex" },
      { name: "AI Agents" },
      { name: "Prompt Engineering" },
    ],
  },
  {
    title: "Tools & Platforms",
    items: [
      { name: "Git / GitHub", icon: GitHub },
      { name: "Oracle Eloqua" },
      { name: "JIRA" },
      { name: "Litmus" },
    ],
  },
]
---

<div class="flex flex-col gap-8">
  {
    GROUPS.map((group) => (
      <div>
        <h3 class="mb-4 text-sm font-semibold tracking-wide uppercase text-yellow-500 dark:text-yellow-300/90">
          {group.title}
        </h3>
        <ul class="flex flex-wrap gap-3">
          {group.items.map(({ name, icon: Icon }) => (
            <li class="flex items-center gap-x-2 px-3 py-1.5 text-sm text-gray-800 transition duration-300 bg-gray-100 border border-gray-300 rounded-full dark:bg-gray-800/60 dark:border-gray-700 dark:text-gray-200 hover:-translate-y-0.5 hover:border-yellow-500/60 hover:shadow-sm dark:hover:border-yellow-400/50">
              {Icon && <Icon class="size-4" />}
              {name}
            </li>
          ))}
        </ul>
      </div>
    ))
  }
</div>
